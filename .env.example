# 환경변수 설정
# 이 파일을 복사하여 .env.local로 만들어 사용하세요

# Google Maps API Key (필수)
# https://console.cloud.google.com/apis/credentials 에서 발급
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 서버 측 Places API 키 이름으로도 사용 가능
# api/*.ts, api-dev-server.mjs 는 GOOGLE_PLACES_API_KEY 또는 VITE_GOOGLE_MAPS_API_KEY 를 읽습니다.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Maps Map ID (선택 - 커스텀 스타일용)
# https://console.cloud.google.com/google/maps-platform/map-management 에서 생성
VITE_GOOGLE_MAPS_LIGHT_MAP_ID=your_light_map_id_here
VITE_GOOGLE_MAPS_DARK_MAP_ID=your_dark_map_id_here

# OpenAI API Key (AI 추천 기능용, Vercel 서버리스에서 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (선택 - 인증/커뮤니티/실시간/스토리지)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 별도 AI 백엔드가 있을 경우 사용 (선택)
# 예: https://your-app.vercel.app/api/ai-recommend
# VITE_AI_API_URL=http://localhost:3000/api/ai-recommend
